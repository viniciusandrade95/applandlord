generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  properties   Property[]
  units        Unit[]
  renters      Renter[]
  leases       Lease[]
  invoices     Invoice[]
  payments     Payment[]
  maintenance  MaintenanceTicket[]
}

model Property {
  id            String   @id @default(cuid())
  ownerId       String
  name          String
  addressLine1  String
  addressLine2  String?
  city          String
  region        String
  postalCode    String
  country       String   @default("Portugal")
  description   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  owner         User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  units         Unit[]
  leases        Lease[]
  maintenance   MaintenanceTicket[]

  @@index([ownerId])
}

model Unit {
  id            String   @id @default(cuid())
  ownerId       String
  propertyId    String
  name          String
  bedrooms      Int      @default(0)
  bathrooms     Float    @default(0)
  floor         String?
  areaSqm       Float?
  monthlyRent   Float
  status        String   @default("Vacant")
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  owner         User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  property      Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  leases        Lease[]
  maintenance   MaintenanceTicket[]

  @@index([ownerId])
  @@index([propertyId])
}

model Renter {
  id            String   @id @default(cuid())
  ownerId       String
  fullName      String
  email         String?
  phone         String?
  governmentId  String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  owner         User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  leases        Lease[]

  @@index([ownerId])
}

model Lease {
  id            String   @id @default(cuid())
  ownerId       String
  propertyId    String
  unitId        String
  renterId      String
  startDate     DateTime
  endDate       DateTime?
  monthlyRent   Float
  depositAmount Float    @default(0)
  dueDay        Int      @default(1)
  status        String   @default("Active")
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  owner         User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  property      Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  unit          Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)
  renter        Renter   @relation(fields: [renterId], references: [id], onDelete: Cascade)
  invoices      Invoice[]

  @@index([ownerId])
  @@index([propertyId])
  @@index([unitId])
  @@index([renterId])
}

model Invoice {
  id            String   @id @default(cuid())
  ownerId       String
  leaseId       String
  period        String
  dueDate       DateTime
  amount        Float
  status        String   @default("Pending")
  paidAt        DateTime?
  paymentMethod String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  owner         User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  lease         Lease    @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  payments      Payment[]

  @@unique([leaseId, period])
  @@index([ownerId])
  @@index([dueDate])
  @@index([status])
}

model Payment {
  id          String   @id @default(cuid())
  ownerId     String
  invoiceId   String
  amount      Float
  paidAt      DateTime @default(now())
  method      String
  reference   String?
  notes       String?
  createdAt   DateTime @default(now())
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@index([invoiceId])
}

model MaintenanceTicket {
  id          String    @id @default(cuid())
  ownerId     String
  propertyId  String?
  unitId      String?
  title       String
  description String?
  priority    String    @default("Normal")
  status      String    @default("Open")
  requestedAt DateTime  @default(now())
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  owner       User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  property    Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  unit        Unit?     @relation(fields: [unitId], references: [id], onDelete: SetNull)

  @@index([ownerId])
  @@index([propertyId])
  @@index([unitId])
  @@index([status])
}
